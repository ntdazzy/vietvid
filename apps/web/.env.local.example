# VietVid web — copy sang .env.local

# Backend app_api (M1). Mặc định khớp uvicorn local.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8099

# Supabase — ĐỂ TRỐNG = dev-mode: đăng nhập bằng dev token qua backend POST /v1/dev/token.
# Khi có project Supabase thật, điền 2 dòng dưới (backend tự verify JWKS, không sửa code).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
