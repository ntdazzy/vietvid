# VietVid .env (M0 tối thiểu). M1+ sẽ tự sinh đầy đủ qua `python -m scripts.sync_env_example`
# sau khi trim registry. Copy file này → .env và điền key.

# ── Engine: LLM (Director/Strategist/Critic) — cần cho render thật ──
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Engine: i2v (Seedance/PiAPI) — render thật. Để "mock" chạy offline không tốn tiền ──
VIDEO_PROVIDER=mock          # mock | seedance  (M0 verify dùng mock)
IMAGE_PROVIDER=mock          # mock | gemini | local
PIAPI_API_KEY=

# ── Engine: giọng (M0 review không bắt buộc; vieneu/vbee cho chất lượng) ──
VIDEO_AUDIO_MODE=auto        # auto (vbee/clone đè) | native (giữ giọng Seedance)
# VOICECLONE_DAEMON_DIR=
# TTS_VIENEU_URL=            # M1: endpoint VieNeu qua Cloudflare Tunnel
# TTS_VIENEU_TOKEN=

# ── M0 tiện ích ──
VIDEO_CLEAN_PLATE_ENABLED=false   # tắt clean-plate (Gemini) khi verify nhanh

# ── M1: SaaS layer (app_api HTTP) ──
# VIETVID_DATABASE_URL=postgresql+psycopg2://vietvid:vietvid@localhost:5432/vietvid
# CREDIT_PRICE_VND=150
# USD_TO_VND=25400
# FREE_GRANT_CREDITS=300        # credit tặng khi bootstrap (BONUS); phải > 1 hold (~105) nếu không user free kẹt 402
# JOB_EXECUTION_MODE=inline     # inline (BackgroundTasks, M1) | queue (Arq, item 2)
# CORS_ORIGINS=*                # production: https://app.vietvid.vn (phẩy phân tách)

# ── M1: Auth (DUAL-MODE) ──
# Để TRỐNG cả 2 nhóm Supabase → dev-mode: verify/phát HS256 bằng DEV_JWT_SECRET (POST /v1/dev/token).
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json   # khoá bất đối xứng (RS256/ES256)
# SUPABASE_JWT_SECRET=                # HS256 legacy (project JWT secret) — dùng nếu chưa bật JWKS
# SUPABASE_JWT_AUD=authenticated
# SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
DEV_JWT_SECRET=vietvid-dev-secret-change-me-please-32b+   # ≥32 bytes (tránh cảnh báo HMAC ngắn)
# VIETVID_DEV_AUTH=true             # bật POST /v1/dev/token (chỉ tác dụng khi ở dev-mode)

# ── M1+ (item 2/3): chưa dùng ở item 1 ──
# REDIS_URL=redis://localhost:6379/0
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=vietvid-media
