# VietVid app_api — env PRODUCTION (đặt trên Render/Fly/Railway). KHÔNG commit giá trị thật.

# Bắt buộc
VIETVID_ENV=production                 # tự tắt dev-token + dev-billing
VIETVID_DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/vietvid?sslmode=require
CORS_ORIGINS=https://app.vietvid.vn    # domain web thật (KHÔNG để "*")

# Auth — Supabase (khuyến nghị). Có cái này thì /v1/dev/token tự tắt.
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
# (nếu không dùng Supabase: đặt DEV_JWT_SECRET ≥32 ký tự + tự phát JWT từ backend của bạn)

# Tiền tệ / credit
CREDIT_PRICE_VND=150
USD_TO_VND=25400
FREE_GRANT_CREDITS=300

# LLM (kịch bản) + ảnh AI — cần để render thật & Tạo ảnh AI
GEMINI_API_KEY=
GROQ_API_KEY=
IMAGE_PROVIDER=gemini

# Video i2v THẬT (bỏ "mock" để ra video thật) — TỐN PHÍ theo PiAPI
VIDEO_PROVIDER=seedance
PIAPI_API_KEY=
VIDEO_CLEAN_PLATE_ENABLED=false

# Thanh toán VNPay (để trống = cổng vnpay báo "chưa cấu hình")
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=https://app.vietvid.vn/billing/return

# Thanh toán MoMo (cổng chính — để trống = cổng momo báo "chưa cấu hình")
VIETVID_MOMO_PARTNER_CODE=
VIETVID_MOMO_ACCESS_KEY=
VIETVID_MOMO_SECRET_KEY=
VIETVID_MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
VIETVID_MOMO_RETURN_URL=https://app.vietvid.vn/billing/return
VIETVID_MOMO_IPN_URL=https://api.vietvid.vn/v1/billing/ipn/momo

# Super-admin (email phẩy phân tách) — vào /app/admin
VIETVID_ADMIN_EMAILS=

# Lưu video lên cloud (R2/S3) — KHÔNG có thì video mất khi redeploy
VIETVID_S3_BUCKET=
VIETVID_S3_ENDPOINT=
VIETVID_S3_ACCESS_KEY=
VIETVID_S3_SECRET_KEY=
VIETVID_S3_PUBLIC_BASE=

# Gửi email thật (reset/verify/invite) — KHÔNG có thì link ghi ra log (dev)
VIETVID_SMTP_HOST=
VIETVID_SMTP_PORT=587
VIETVID_SMTP_USER=
VIETVID_SMTP_PASSWORD=
VIETVID_SMTP_FROM=VietVid <no-reply@vietvid.vn>

# URL frontend (dựng link trong email + share)
VIETVID_APP_URL=https://app.vietvid.vn

# Giọng VieNeu (tuỳ chọn; không có thì tự dùng edge-tts)
# TTS_VIENEU_URL=
# TTS_VIENEU_TOKEN=
